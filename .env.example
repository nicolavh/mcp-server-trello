TRELLO_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_api_token

# Optional: absolute path to dist/index.js (for Cursor MCP "command"/launcher). If unset, scripts/cursor-mcp.sh uses <repo>/dist/index.js
MCP_TRELLO_ENTRY=

# Optional defaults (used only if you omit params in tools that accept them)
TRELLO_DEFAULT_BOARD_ID=
TRELLO_DEFAULT_LIST_ID=

